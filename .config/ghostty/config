# ===== 字体 =====
font-family = "JetBrains Mono"
font-family-bold = "JetBrains Mono Bold"
font-family-italic = "JetBrains Mono Italic"
font-family-bold-italic = "JetBrains Mono Bold Italic"
font-size = 13
font-thicken = true

# 中文字体映射
font-codepoint-map = U+4E00-U+9FFF,U+3000-U+303F,U+FF00-U+FFEF=LXGW WenKai Mono

# 字体特性（JetBrains Mono 连字）
font-feature = calt
font-feature = liga

# ===== 主题与外观 =====
theme = "0x96f"
background-opacity = 0.92
background-blur-radius = 20
window-padding-x = 8
window-padding-y = 6
window-theme = auto

# 调整窗口圆角（macOS）
macos-window-shadow = true

# ===== 光标 =====
cursor-style = block
cursor-style-blink = false
cursor-color = "#ffcc00"
shell-integration-features = sudo,no-cursor,title

# ===== 窗口行为 =====
window-save-state = always
confirm-close-surface = false
window-height = 30
window-width = 100
window-decoration = true

# ===== macOS 专属 =====
macos-titlebar-style = transparent
macos-option-as-alt = true
macos-secure-input-indication = true

# ===== 终端行为 =====
copy-on-select = clipboard
mouse-hide-while-typing = true
scrollback-limit = 120000
desktop-notifications = true
link-url = true
link-previews = true
shell-integration = detect

# 粘贴时确认（防止误粘贴多行命令）
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
clipboard-trim-trailing-spaces = true

# ===== 性能 =====
# `gpu-renderer` 在当前 Ghostty 版本已不支持，删除避免启动报错
adjust-cell-height = 0
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true
window-inherit-font-size = true

# ===== Quick Terminal =====
keybind = global:alt+`=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-size = 40%
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.12

# ===== 快捷键 - 窗口管理 =====
keybind = super+shift+,=reload_config
keybind = super+,=open_config
keybind = super+shift+p=toggle_command_palette
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+w=close_surface
keybind = super+shift+enter=toggle_fullscreen
keybind = super+shift+n=new_window

# ===== 快捷键 - 分屏导航 =====
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:up
keybind = super+alt+down=goto_split:down

# ===== 快捷键 - 字体调整 =====
keybind = super+plus=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+0=reset_font_size

# ===== 快捷键 - 滚动 =====
keybind = super+up=scroll_page_up
keybind = super+down=scroll_page_down
keybind = super+home=scroll_to_top
keybind = super+end=scroll_to_bottom

# ===== 快捷键 - 标签页 =====
keybind = super+t=new_tab
keybind = super+shift+]=next_tab
keybind = super+shift+[=previous_tab
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5

# ===== 快捷键 - 搜索 =====
keybind = super+f=start_search
keybind = super+shift+f=end_search
keybind = super+g=navigate_search:next
keybind = super+shift+g=navigate_search:previous

# ===== 快捷键 - 复制粘贴 =====
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = super+shift+v=paste_from_clipboard

# ===== 快捷键 - 其他 =====
keybind = super+shift+i=inspector:toggle
# `unicode_input` / `Screenshot:screen` 不是当前版本支持的动作
